<!DOCTYPE html>
<html lang="zh-CN" data-theme="system">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — 拼豆管理器</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'><text y='14' font-size='14'>🧩</text></svg>">
</head>
<body>
  <nav class="navbar glass-bar">
    <div class="navbar__inner">
      <a href="/" class="navbar__brand">🧩 拼豆管理器</a>
      <button class="navbar__toggle" id="nav-toggle" aria-label="菜单" aria-expanded="false">
        <span class="navbar__toggle-icon"></span>
      </button>
      <ul class="navbar__links" id="nav-links">
        <li><a href="/" class="navbar__link <%= currentPage === 'home' ? 'navbar__link--active' : '' %>">首页</a></li>
        <li><a href="/colors" class="navbar__link <%= currentPage === 'colors' ? 'navbar__link--active' : '' %>">色号</a></li>
        <li><a href="/inventory" class="navbar__link <%= currentPage === 'inventory' ? 'navbar__link--active' : '' %>">库存</a></li>
        <li><a href="/patterns" class="navbar__link <%= currentPage === 'patterns' ? 'navbar__link--active' : '' %>">图纸</a></li>
        <li><a href="/cart" class="navbar__link <%= currentPage === 'cart' ? 'navbar__link--active' : '' %>">购物车<span class="navbar__badge<%= (cartCount || 0) > 0 ? '' : ' navbar__badge--zero' %>" id="cart-badge"><%= cartCount || 0 %></span></a></li>
        <li><a href="/color-diff" class="navbar__link <%= currentPage === 'color-diff' ? 'navbar__link--active' : '' %>">色差计算器</a></li>
      </ul>
      <button class="navbar__theme-btn" id="theme-toggle" aria-label="切换主题" title="切换主题">☀️</button>
    </div>
  </nav>

  <script src="/js/app.js"></script>

  <main class="main-content">
    <%- body %>
  </main>

</body>
</html>
